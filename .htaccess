# ============================================
# Private Offer Share - Security Configuration
# ============================================

RewriteEngine On

# ---------- Admin Panel Hide ----------
# Change this URL to your secret panel
RewriteRule ^secure-panel-8x7k2m$ admin.html [L,QSA]

# Block direct admin.html access
RewriteCond %{THE_REQUEST} admin\.html [NC]
RewriteRule ^ - [F,L]

# ---------- Block sensitive files ----------
<FilesMatch "^(firebase-config\.js|firestore\.rules|firebase\.json|package\.json|package-lock\.json|\.env|README\.md|CHANGELOG\.md|LICENSE)">
    Order allow,deny
    Deny from all
</FilesMatch>

# ---------- Block directory access ----------
RedirectMatch 404 /\.git
RedirectMatch 404 /\.github
RedirectMatch 404 /scripts
RedirectMatch 404 /node_modules
RedirectMatch 404 /\.vscode
RedirectMatch 404 /\.idea

# ---------- Directory listing off ----------
Options -Indexes

# ---------- Security headers ----------
<IfModule mod_headers.c>
    # Hide server info
    Header unset Server
    Header unset X-Powered-By
    
    # Security headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    
    # CSP - Content Security Policy (blocks XSS)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https://*.firebaseio.com https://*.googleapis.com https://*.cloudinary.com wss://*.firebaseio.com; frame-src 'self' https://*.firebaseapp.com;"
    
    # HSTS (force HTTPS)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ---------- Hotlink protection ----------
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?privateoffershare\.com [NC]
    RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?google\.com [NC]
    RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?facebook\.com [NC]
    RewriteRule \.(jpg|jpeg|png|gif|svg|webp)$ - [NC,F,L]
</IfModule>

# ---------- Block bad bots ----------
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (bot|crawler|spider|scraper|curl|wget|python|java) [NC]
    RewriteCond %{HTTP_USER_AGENT} !(googlebot|bingbot|facebookexternalhit) [NC]
    RewriteRule ^ - [F,L]
</IfModule>

# ---------- Cache control ----------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

# ---------- Gzip compression ----------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json text/plain text/xml
</IfModule>

# ---------- Error pages ----------
ErrorDocument 403 /index.html
ErrorDocument 404 /index.html
ErrorDocument 500 /index.html