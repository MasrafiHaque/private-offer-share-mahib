rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ---------- PRODUCTS ----------
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.currentPrice is number &&
        request.resource.data.currentPrice >= 0 &&
        request.resource.data.affiliateLink is string;
      allow update, delete: if isAdmin();
    }

    // ---------- CATEGORIES ----------
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ---------- USERS ----------
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) &&
        request.resource.data.role == 'user' &&
        request.resource.data.status == 'active';
      allow update: if isAuthenticated() &&
        (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // ---------- SITE SETTINGS ----------
    match /siteSettings/{setting} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- ANALYTICS (tracking) ----------
    match /analytics/{date} {
      allow read: if isAdmin();
      allow create, update: if true;
      allow delete: if false;
    }

    // ---------- BUY CLICKS ----------
    match /buyClicks/{clickId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.productId is string;
      allow update, delete: if false;
    }

    // ---------- TELEGRAM CLICKS ----------
    match /telegramClicks/{clickId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // ---------- USER EVENTS ----------
    match /userEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // ---------- SEARCH QUERIES ----------
    match /searchQueries/{queryId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // ---------- AUTOMATION STATUS (Price Update Progress) ----------
    match /automationStatus/{doc} {
      allow read: if isAdmin();
      allow write: if false; // শুধু Admin SDK (Cloud Function / GitHub Action) লিখতে পারবে
    }

    // ---------- DEFAULT DENY ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
